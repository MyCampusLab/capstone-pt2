	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Registrasi Akun Baru",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"hero@visionsafe.id\",\n    \"password\": \"SuperStrong123!\"\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/auth/v1/signup",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"auth",
								"v1",
								"signup"
							]
						},
						"description": "Mendaftarkan email dan password baru ke Supabase Auth."
					},
					"response": []
				},
				{
					"name": "Login Akun (Dapatkan JWT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.environment.set(\"JWT_TOKEN\", jsonData.access_token);",
									"    pm.environment.set(\"REFRESH_TOKEN\", jsonData.refresh_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"hero@visionsafe.id\",\n    \"password\": \"SuperStrong123!\"\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/auth/v1/token?grant_type=password",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"auth",
								"v1",
								"token"
							],
							"query": [
								{
									"key": "grant_type",
									"value": "password"
								}
							]
						},
						"description": "Mengirim kredensial dan mendapatkan JWT Access Token."
					},
					"response": []
				},
				{
					"name": "Logout Akun",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{JWT_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/auth/v1/logout",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"auth",
								"v1",
								"logout"
							]
						},
						"description": "Menghapus sesi login di sisi server cloud."
					},
					"response": []
				}
			]
		},
		{
			"name": "Telemetry & Eye Distance Logs",
			"item": [
				{
					"name": "Simpan Log Telemetri Baru (Batch Insert)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{JWT_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "apikey",
								"value": "{{SUPABASE_ANON_KEY}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "[\n    {\n        \"distance\": 34.5,\n        \"is_violation\": true,\n        \"is_blinking\": false\n    },\n    {\n        \"distance\": 39.1,\n        \"is_violation\": false,\n        \"is_blinking\": true\n    }\n]"
						},
						"url": {
							"raw": "{{BASE_URL}}/rest/v1/telemetry",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"rest",
								"v1",
								"telemetry"
							]
						},
						"description": "Mengirim kumpulan data sensor pengawasan mata (jarak dalam cm dan status kedipan) ke database cloud."
					},
					"response": []
				},
				{
					"name": "Ambil Histori Telemetri",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{JWT_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "apikey",
								"value": "{{SUPABASE_ANON_KEY}}"
							}
						],
						"url": {
							"raw": "{{BASE_URL}}/rest/v1/telemetry?select=id,distance,is_violation,is_blinking,created_at&order=created_at.desc",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"rest",
								"v1",
								"telemetry"
							],
							"query": [
								{
									"key": "select",
									"value": "id,distance,is_violation,is_blinking,created_at"
								},
								{
									"key": "order",
									"value": "created_at.desc"
								}
							]
						},
						"description": "Mengambil log history mata milik user bersangkutan (Terlindungi RLS PostgreSQL)."
					},
					"response": []
				}
			]
		},
